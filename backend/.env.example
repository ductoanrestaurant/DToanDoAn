# =====================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Copy file này thành .env và .env.docker, rồi điền giá trị thật vào
# ⚠️ KHÔNG commit file .env hay .env.docker lên git!
# =====================================================

# PostgreSQL
POSTGRES_DB=DucToanRestaurant
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password-here

# JWT Secret Key (Base64 encoded, ít nhất 32 ký tự)
JWT_SECRET=your-jwt-secret-here

# Custom API Keys
NHANVIEN_API_KEY=your-api-key-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent

# PayOS Payment Gateway
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Upload Directory (chỉ cần set khi chạy local không dùng Docker)
# UPLOAD_DIR=D:/DoAnTotNghiep/demo1/backend/image-dir

# OpenWeatherMap (miễn phí, đăng ký tại https://openweathermap.org/api)
WEATHER_API_KEY=your-openweathermap-api-key
WEATHER_CITY=Ho Chi Minh
